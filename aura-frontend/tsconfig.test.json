{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/app/redirects.ts",
    "src/features/auth/roles.ts",
    "src/lib/apiError.ts",
    "src/lib/jwt.ts",
    "src/features/organizations/insights.ts",
    "src/features/reviews/navigation.ts",
    "src/features/reviews/reanalyze.ts",
    "src/features/reviews/summary.ts",
    "src/features/sources/navigation.ts",
    "src/features/sources/form.ts",
    "src/features/sources/schedule.ts",
    "src/lib/constants.ts",
    "src/types/auth.ts",
    "src/types/organization.ts",
    "src/types/review.ts",
    "src/types/source.ts",
    "tests/**/*.ts"
  ]
}
